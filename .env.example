# Supabase Client Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Storage Encryption Key
EXPO_PUBLIC_STORAGE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=your-firebase-web-client-id
FIREBASE_PROJECT_ID=your-firebase-project-id

# App Environment & Monitoring
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Supabase Deployment / CLI Configuration
# JWT Secret for custom authentication / verification in Edge Functions
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Access Token for Supabase CLI operations (e.g. deployments)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Crash Report Email (Resend - https://resend.com)
# Get your API key from https://resend.com/api-keys
# Add to Supabase project: supabase secrets set RESEND_API_KEY=your-key
RESEND_API_KEY=re_xxxxxxxxxxxx
